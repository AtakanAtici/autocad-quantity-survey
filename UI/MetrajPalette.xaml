<UserControl x:Class="BetonMetraj.UI.MetrajPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FAFAFA" MinWidth="380">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="Button" x:Key="ElemanBtn">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- Üst başlık -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="8,6">
            <StackPanel>
                <TextBlock Text="DEVA YAZILIM" FontSize="12" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="INSAAT360 METRAJ HESAPLAMA ENTEGRASYONU" FontSize="9"
                           Foreground="#90CAF9" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Çizim Birimi -->
        <GroupBox DockPanel.Dock="Top" Header="Birim">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="cmbBirim" Width="90" SelectedIndex="1" FontSize="10">
                    <ComboBoxItem Content="mm"/>
                    <ComboBoxItem Content="cm"/>
                    <ComboBoxItem Content="m"/>
                </ComboBox>
            </StackPanel>
        </GroupBox>

        <!-- Eleman Ekleme Butonları -->
        <GroupBox DockPanel.Dock="Top" Header="Eleman">
            <UniformGrid Columns="3">
                <Button Style="{StaticResource ElemanBtn}" Click="BtnTemelEkle_Click"
                        Background="#FFF9C4" Content="Temel"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnKolonEkle_Click"
                        Background="#BBDEFB" Content="Kolon"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnKirisEkle_Click"
                        Background="#C8E6C9" Content="Kiriş"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnDosemeEkle_Click"
                        Background="#FCE4EC" Content="Döşeme"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnPerdeEkle_Click"
                        Background="#F3E5F5" Content="Perde"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnMerdivenEkle_Click"
                        Background="#E0F2F1" Content="Merdiven"/>
            </UniformGrid>
        </GroupBox>

        <!-- AutoCAD'den Seç Butonu -->
        <GroupBox DockPanel.Dock="Top" Header="Seçim">
            <UniformGrid Columns="2">
                <Button Style="{StaticResource ActionBtn}" Click="BtnAcadSec_Click"
                        Background="#E8F5E9" Content="Nesne Seç"/>
                <Button Style="{StaticResource ActionBtn}" Click="BtnAcadPolylineSec_Click"
                        Background="#E8F5E9" Content="Polyline Alan"/>
            </UniformGrid>
        </GroupBox>

        <!-- Eleman Listesi -->
        <GroupBox DockPanel.Dock="Top" Header="Liste" Height="140">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" x:Name="lstElemanlar"
                         SelectionMode="Extended"
                         FontSize="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BetonHacmi, StringFormat='{}{0:F2}'}"
                                           FontWeight="Bold" Foreground="#1565C0"
                                           Margin="4,0" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="1" Content="Seçileni Sil" Click="BtnSil_Click"
                        Style="{StaticResource ActionBtn}"
                        Background="#FFEBEE" HorizontalAlignment="Right"/>
            </Grid>
        </GroupBox>

        <!-- Özet -->
        <GroupBox DockPanel.Dock="Top" Header="Hacim (m³)">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/><RowDefinition/><RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Text="T/K/Ki:" FontSize="10"/>
                <TextBlock Grid.Column="1" Grid.Row="0" x:Name="lblTemelKolonKiris" Text="0.00" FontSize="10" HorizontalAlignment="Right"/>

                <TextBlock Grid.Column="0" Grid.Row="1" Text="D/P/M:" FontSize="10"/>
                <TextBlock Grid.Column="1" Grid.Row="1" x:Name="lblDosemePerdeMerdiven" Text="0.00" FontSize="10" HorizontalAlignment="Right"/>

                <Border Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2"
                        BorderBrush="#1565C0" BorderThickness="0,1,0,0" Margin="0,2,0,0">
                    <Grid>
                        <TextBlock Text="Toplam:" FontWeight="Bold" FontSize="11"/>
                        <TextBlock x:Name="lblToplam" Text="0.00 m³"
                                   FontWeight="Bold" FontSize="11" Foreground="#C62828"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Rapor Butonları -->
        <GroupBox DockPanel.Dock="Top" Header="Rapor">
            <UniformGrid Columns="3">
                <Button Style="{StaticResource ActionBtn}" Click="BtnExcel_Click"
                        Background="#E8F5E9" Content="Excel"/>
                <Button Style="{StaticResource ActionBtn}" Click="BtnTxt_Click"
                        Background="#E3F2FD" Content="TXT"/>
                <Button Style="{StaticResource ActionBtn}" Click="BtnTemizle_Click"
                        Background="#FFEBEE" Content="Temizle"/>
            </UniformGrid>
        </GroupBox>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#E0E0E0" Padding="6,3">
            <TextBlock x:Name="lblStatus" Text="Hazır" FontSize="9" Foreground="#555"/>
        </Border>
    </DockPanel>
</UserControl>
