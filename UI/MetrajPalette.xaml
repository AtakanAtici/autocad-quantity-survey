<UserControl x:Class="BetonMetraj.UI.MetrajPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FAFAFA" MinWidth="380">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="Button" x:Key="ElemanBtn">
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="6,4"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- Üst başlık -->
        <Border DockPanel.Dock="Top" Background="#1565C0" Padding="12,8">
            <StackPanel>
                <TextBlock Text="BETON METRAJ HESABI" FontSize="14" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="AutoCAD Şantiye Çizimi Entegrasyonu" FontSize="10"
                           Foreground="#90CAF9" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Çizim Birimi -->
        <GroupBox DockPanel.Dock="Top" Header="Çizim Birimi">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="AutoCAD Birim:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbBirim" Width="100" SelectedIndex="1">
                    <ComboBoxItem Content="Milimetre (mm)"/>
                    <ComboBoxItem Content="Santimetre (cm)"/>
                    <ComboBoxItem Content="Metre (m)"/>
                </ComboBox>
            </StackPanel>
        </GroupBox>

        <!-- Eleman Ekleme Butonları -->
        <GroupBox DockPanel.Dock="Top" Header="Eleman Ekle">
            <UniformGrid Columns="3">
                <Button Style="{StaticResource ElemanBtn}" Click="BtnTemelEkle_Click"
                        Background="#FFF9C4" Content="🏗 Temel"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnKolonEkle_Click"
                        Background="#BBDEFB" Content="🔵 Kolon"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnKirisEkle_Click"
                        Background="#C8E6C9" Content="🔩 Kiriş"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnDosemeEkle_Click"
                        Background="#FCE4EC" Content="🟥 Döşeme"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnPerdeEkle_Click"
                        Background="#F3E5F5" Content="🧱 Perde"/>
                <Button Style="{StaticResource ElemanBtn}" Click="BtnMerdivenEkle_Click"
                        Background="#E0F2F1" Content="🪜 Merdiven"/>
            </UniformGrid>
        </GroupBox>

        <!-- AutoCAD'den Seç Butonu -->
        <GroupBox DockPanel.Dock="Top" Header="AutoCAD Seçimi">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="11" FontWeight="Normal"
                           Foreground="#555" Margin="0,0,0,6"
                           Text="AutoCAD çiziminden bir nesne seçerek boyutları otomatik okutun."/>
                <UniformGrid Columns="2">
                    <Button Style="{StaticResource ActionBtn}" Click="BtnAcadSec_Click"
                            Background="#E8F5E9" Content="📐 Çizimden Seç"/>
                    <Button Style="{StaticResource ActionBtn}" Click="BtnAcadPolylineSec_Click"
                            Background="#E8F5E9" Content="📏 Polyline Alan"/>
                </UniformGrid>
            </StackPanel>
        </GroupBox>

        <!-- Eleman Listesi -->
        <GroupBox DockPanel.Dock="Top" Header="Eklenen Elemanlar" Height="200">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" x:Name="lstElemanlar"
                         SelectionMode="Extended"
                         FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BetonHacmi, StringFormat='{}{0:F3} m³'}"
                                           FontWeight="Bold" Foreground="#1565C0"
                                           Margin="8,0" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="1" Content="Seçileni Sil" Click="BtnSil_Click"
                        Style="{StaticResource ActionBtn}"
                        Background="#FFEBEE" HorizontalAlignment="Right"/>
            </Grid>
        </GroupBox>

        <!-- Özet -->
        <GroupBox DockPanel.Dock="Top" Header="Özet">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/><RowDefinition/><RowDefinition/>
                    <RowDefinition/><RowDefinition/><RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Text="Temel:" FontWeight="Normal" FontSize="11"/>
                <TextBlock Grid.Column="1" Grid.Row="0" x:Name="lblTemel" Text="0.000 m³" FontSize="11" HorizontalAlignment="Right"/>

                <TextBlock Grid.Column="0" Grid.Row="1" Text="Kolon:" FontWeight="Normal" FontSize="11"/>
                <TextBlock Grid.Column="1" Grid.Row="1" x:Name="lblKolon" Text="0.000 m³" FontSize="11" HorizontalAlignment="Right"/>

                <TextBlock Grid.Column="0" Grid.Row="2" Text="Kiriş:" FontWeight="Normal" FontSize="11"/>
                <TextBlock Grid.Column="1" Grid.Row="2" x:Name="lblKiris" Text="0.000 m³" FontSize="11" HorizontalAlignment="Right"/>

                <TextBlock Grid.Column="0" Grid.Row="3" Text="Döşeme:" FontWeight="Normal" FontSize="11"/>
                <TextBlock Grid.Column="1" Grid.Row="3" x:Name="lblDoseme" Text="0.000 m³" FontSize="11" HorizontalAlignment="Right"/>

                <TextBlock Grid.Column="0" Grid.Row="4" Text="Perde Duvar:" FontWeight="Normal" FontSize="11"/>
                <TextBlock Grid.Column="1" Grid.Row="4" x:Name="lblPerde" Text="0.000 m³" FontSize="11" HorizontalAlignment="Right"/>

                <TextBlock Grid.Column="0" Grid.Row="5" Text="Merdiven:" FontWeight="Normal" FontSize="11"/>
                <TextBlock Grid.Column="1" Grid.Row="5" x:Name="lblMerdiven" Text="0.000 m³" FontSize="11" HorizontalAlignment="Right"/>

                <Border Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="2"
                        BorderBrush="#1565C0" BorderThickness="0,1,0,0" Margin="0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TOPLAM:" FontWeight="Bold" FontSize="13"/>
                        <TextBlock Grid.Column="1" x:Name="lblToplam" Text="0.000 m³"
                                   FontWeight="Bold" FontSize="13" Foreground="#C62828"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Rapor Butonları -->
        <GroupBox DockPanel.Dock="Top" Header="Rapor">
            <UniformGrid Columns="3">
                <Button Style="{StaticResource ActionBtn}" Click="BtnExcel_Click"
                        Background="#E8F5E9" Content="📊 Excel"/>
                <Button Style="{StaticResource ActionBtn}" Click="BtnTxt_Click"
                        Background="#E3F2FD" Content="📄 TXT"/>
                <Button Style="{StaticResource ActionBtn}" Click="BtnTemizle_Click"
                        Background="#FFEBEE" Content="🗑 Temizle"/>
            </UniformGrid>
        </GroupBox>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#E0E0E0" Padding="8,4">
            <TextBlock x:Name="lblStatus" Text="Hazır." FontSize="11" Foreground="#555"/>
        </Border>
    </DockPanel>
</UserControl>
