<Window x:Class="BetonMetraj.UI.Dialogs.KolonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kolon Eleman Girişi" Height="400" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Label"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Margin" Value="0,4,0,0"/></Style>
        <Style TargetType="TextBox"><Setter Property="Padding" Value="4,3"/><Setter Property="Margin" Value="0,2,0,4"/><Setter Property="BorderBrush" Value="#AAAAAA"/></Style>
        <Style TargetType="ComboBox"><Setter Property="Padding" Value="4,3"/><Setter Property="Margin" Value="0,2,0,4"/></Style>
        <Style TargetType="Button"><Setter Property="Padding" Value="16,6"/><Setter Property="Margin" Value="4"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Kolon Bilgileri" FontSize="15" FontWeight="Bold"
                   Foreground="#1565C0" Margin="0,0,0,10"/>

        <Label Grid.Row="1" Content="Kesit Tipi:"/>
        <ComboBox Grid.Row="2" x:Name="cmbKesit" SelectedIndex="0"
                  SelectionChanged="cmbKesit_SelectionChanged">
            <ComboBoxItem Content="Dikdörtgen"/>
            <ComboBoxItem Content="Daire"/>
            <ComboBoxItem Content="L Kesiti"/>
            <ComboBoxItem Content="T Kesiti"/>
        </ComboBox>

        <Label Grid.Row="3" Content="Etiket (örn: K1, K-A1):"/>
        <TextBox Grid.Row="4" x:Name="txtEtiket"/>

        <Label Grid.Row="5" Content="Kat:"/>
        <TextBox Grid.Row="6" x:Name="txtKat" Text="Zemin"/>

        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0" x:Name="lblB" Content="b - Genişlik (m):"/>
            <Label Grid.Column="1" Grid.Row="0" x:Name="lblH" Content="h - Derinlik (m):"/>
            <Label Grid.Column="2" Grid.Row="0"              Content="Boy (m):"/>

            <TextBox Grid.Column="0" Grid.Row="1" x:Name="txtB"/>
            <TextBox Grid.Column="1" Grid.Row="1" x:Name="txtH"/>
            <TextBox Grid.Column="2" Grid.Row="1" x:Name="txtBoy"/>
        </Grid>

        <StackPanel Grid.Row="8" x:Name="capPanel" Visibility="Collapsed">
            <Label Content="Çap (m):"/>
            <TextBox x:Name="txtCap"/>
        </StackPanel>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="İptal" Click="BtnIptal_Click" Background="#E0E0E0"/>
            <Button Content="Ekle" Click="BtnEkle_Click" Background="#1565C0" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
