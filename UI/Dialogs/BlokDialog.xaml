<Window x:Class="BetonMetraj.UI.Dialogs.BlokDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blok Eleman" SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="15">
        <TextBlock Text="Blok İçeriği:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBlock x:Name="lblIcerik" Text="..." Margin="0,0,0,10"/>

        <TextBlock Text="Blok Adı:" Margin="0,0,0,2"/>
        <TextBox x:Name="txtBlokAdi" Margin="0,0,0,10" Width="200"/>

        <TextBlock Text="Kalınlık (m):" Margin="0,0,0,2"/>
        <TextBox x:Name="txtKalınlik" Text="0.20" Margin="0,0,0,10" Width="100"/>

        <TextBlock Text="Toplam Alan:" Margin="0,0,0,2"/>
        <TextBlock x:Name="lblAlan" Text="0.00 m²" Margin="0,0,0,10"/>

        <TextBlock Text="Hesaplanan Hacim:" FontWeight="Bold" Margin="0,0,0,2"/>
        <TextBlock x:Name="lblHacim" Text="0.00 m³" FontSize="14" Foreground="#1565C0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="İptal" IsCancel="True" Width="70" Margin="0,0,5,0"/>
            <Button Content="Ekle" IsDefault="True" Click="BtnEkle_Click" Width="70"/>
        </StackPanel>
    </StackPanel>
</Window>
