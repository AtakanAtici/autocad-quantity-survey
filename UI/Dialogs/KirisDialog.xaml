<Window x:Class="BetonMetraj.UI.Dialogs.KirisDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kiriş Eleman Girişi" Height="360" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Label"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Margin" Value="0,4,0,0"/></Style>
        <Style TargetType="TextBox"><Setter Property="Padding" Value="4,3"/><Setter Property="Margin" Value="0,2,0,4"/><Setter Property="BorderBrush" Value="#AAAAAA"/></Style>
        <Style TargetType="Button"><Setter Property="Padding" Value="16,6"/><Setter Property="Margin" Value="4"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Kiriş Bilgileri" FontSize="15" FontWeight="Bold"
                   Foreground="#1565C0" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Etiket (örn: K1-2, KX1):"/>
            <Label Grid.Column="1" Grid.Row="0" Content="Kat:"/>
            <TextBox Grid.Column="0" Grid.Row="1" x:Name="txtEtiket"/>
            <TextBox Grid.Column="1" Grid.Row="1" x:Name="txtKat" Text="Zemin"/>
        </Grid>

        <Border Grid.Row="2" Background="#E3F2FD" CornerRadius="4" Padding="8" Margin="0,4">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#0D47A1"
                Text="Not: Döşeme kalınlığı girilerek kirişin döşemeyle çakışan kısmı çıkarılır (çift sayım önlenir)."/>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0" Content="bw (m):"/>
            <Label Grid.Column="1" Grid.Row="0" Content="h Toplam (m):"/>
            <Label Grid.Column="2" Grid.Row="0" Content="Döşeme k. (m):"/>
            <Label Grid.Column="3" Grid.Row="0" Content="Uzunluk (m):"/>

            <TextBox Grid.Column="0" Grid.Row="1" x:Name="txtBw"/>
            <TextBox Grid.Column="1" Grid.Row="1" x:Name="txtH"/>
            <TextBox Grid.Column="2" Grid.Row="1" x:Name="txtDoseme" Text="0"/>
            <TextBox Grid.Column="3" Grid.Row="1" x:Name="txtUzunluk"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="İptal" Click="BtnIptal_Click" Background="#E0E0E0"/>
            <Button Content="Ekle" Click="BtnEkle_Click" Background="#1565C0" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
