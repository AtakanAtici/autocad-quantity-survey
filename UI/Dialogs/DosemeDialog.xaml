<Window x:Class="BetonMetraj.UI.Dialogs.DosemeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Döşeme Eleman Girişi" Height="380" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Label"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Margin" Value="0,4,0,0"/></Style>
        <Style TargetType="TextBox"><Setter Property="Padding" Value="4,3"/><Setter Property="Margin" Value="0,2,0,4"/><Setter Property="BorderBrush" Value="#AAAAAA"/></Style>
        <Style TargetType="ComboBox"><Setter Property="Padding" Value="4,3"/><Setter Property="Margin" Value="0,2,0,4"/></Style>
        <Style TargetType="Button"><Setter Property="Padding" Value="16,6"/><Setter Property="Margin" Value="4"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Döşeme Bilgileri" FontSize="15" FontWeight="Bold"
                   Foreground="#1565C0" Margin="0,0,0,10"/>

        <Label Grid.Row="1" Content="Döşeme Tipi:"/>
        <ComboBox Grid.Row="2" x:Name="cmbTip" SelectedIndex="0"
                  SelectionChanged="cmbTip_SelectionChanged">
            <ComboBoxItem Content="Düz Döşeme"/>
            <ComboBoxItem Content="Nervurlu Döşeme"/>
            <ComboBoxItem Content="Asma Döşeme"/>
            <ComboBoxItem Content="Hollow Core"/>
        </ComboBox>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Etiket:"/>
            <Label Grid.Column="1" Grid.Row="0" Content="Kat:"/>
            <TextBox Grid.Column="0" Grid.Row="1" x:Name="txtEtiket"/>
            <TextBox Grid.Column="1" Grid.Row="1" x:Name="txtKat" Text="Zemin"/>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Grid.Row="0" Content="Alan (m²):"/>
            <Label Grid.Column="1" Grid.Row="0" Content="Kalınlık (m):"/>
            <TextBox Grid.Column="0" Grid.Row="1" x:Name="txtAlan"/>
            <TextBox Grid.Column="1" Grid.Row="1" x:Name="txtKalinlik"/>
        </Grid>

        <StackPanel Grid.Row="5" x:Name="nervurPanel" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Grid.Column="0" Grid.Row="0" Content="Nervur Aralığı (m):"/>
                <Label Grid.Column="1" Grid.Row="0" Content="Nervur Genişliği (m):"/>
                <TextBox Grid.Column="0" Grid.Row="1" x:Name="txtNervurAraligi"/>
                <TextBox Grid.Column="1" Grid.Row="1" x:Name="txtNervurGenisligi"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="İptal" Click="BtnIptal_Click" Background="#E0E0E0"/>
            <Button Content="Ekle" Click="BtnEkle_Click" Background="#1565C0" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
