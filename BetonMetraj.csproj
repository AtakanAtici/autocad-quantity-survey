<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <AssemblyName>BetonMetraj</AssemblyName>
    <RootNamespace>BetonMetraj</RootNamespace>
    <OutputType>Library</OutputType>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <PlatformTarget>x64</PlatformTarget>
    <LangVersion>9.0</LangVersion>
  </PropertyGroup>

  <!--
    AutoCAD .NET API referansları:
    Bu DLL'ler AutoCAD kurulum dizininden kopyalanmalı veya NuGet paketi kullanılmalı.
    Varsayılan yol: C:\Program Files\Autodesk\AutoCAD 2024\
    
    Alternatif: NuGet - AutoCAD.NET veya Autodesk.AutoCAD.All paketlerini kullanın.
    NuGet paketi varsa aşağıdaki Reference bloklarını kaldırıp NuGet kullanın.
  -->
  <ItemGroup>
    <!-- AutoCAD 2024+ NuGet paketi -->
    <PackageReference Include="AutoCAD.NET" Version="24.3.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.102.2" />
  </ItemGroup>

</Project>
